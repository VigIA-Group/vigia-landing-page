---
import CompanyDb from "../../database/company.json";
import Bell from "../../icons/Bell.astro";
import Camera from "../../icons/Camera.astro";
import Puzzle from "../../icons/Puzzle.astro";
// Asegúrate de que la ruta del JSON sea correcta según tu estructura
const { whyToUse } = CompanyDb;
---

<section class="bg-background text-text py-20 px-6" id="why-us">
  <div class="max-w-7xl mx-auto">
    <h2 class="text-5xl md:text-6xl font-medium mb-16 tracking-tight">
      Por qué elegir VigIA
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      {
        whyToUse.map((item) => (
          <div class="flex flex-col gap-4">
            <div class="text-2xl mb-2">
              {item.icon === "camera" ? (
                <Camera />
              ) : item.icon === "bell" ? (
                <Bell />
              ) : (
                <Puzzle />
              )}
            </div>

            <h3 class="text-xl font-semibold leading-snug">{item.reason}</h3>

            <p class="text-muted text-lg leading-relaxed">
              {item.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
