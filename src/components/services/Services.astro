---
import ServicesDb from "../../database/services.json";
import type { Services } from "../../models/Service";

const services = ServicesDb as Services;
---

<section id="services" class="bg-black text-white overflow-hidden">
  {
    services.map((service) => (
      <div class="service-pin-container relative h-screen w-full overflow-hidden">
        <div class="horizontal-track flex h-full w-max will-change-transform">
          <div class="panel w-screen h-screen flex-shrink-0 relative flex flex-col justify-center px-6 md:px-24">
            <div class="absolute inset-0 z-0">
              <img
                src={service.image}
                alt={service.serviceName}
                class="w-full h-full object-cover opacity-30"
              />
              <div class="absolute inset-0 bg-gradient-to-r from-black/90 via-black/80 to-black/90" />
            </div>

            <div class="relative z-10 w-full max-w-4xl flex flex-col items-start gap-4 md:gap-6">
              <h2 class="service-anim-text text-4xl md:text-6xl lg:text-8xl font-semibold leading-tight m-0">
                {service.serviceName}
              </h2>
              <p class="service-anim-text text-base md:text-xl font-light text-white/80 leading-relaxed m-0 max-w-2xl">
                {service.description}
              </p>

              <div
                class="service-anim-text mt-8 flex items-center gap-4 text-white/60 cursor-pointer nav-btn"
                data-target-index="1"
              >
                <span class="text-xs md:text-sm tracking-[0.15em] uppercase hover:text-white transition-colors">
                  Ver Detalles
                </span>
                <div class="w-16 h-[1px] bg-white/30" />
                <svg
                  class="w-5 h-5"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.5"
                    d="M17 8l4 4m0 0l-4 4m4-4H3"
                  />
                </svg>
              </div>
            </div>
          </div>

          {service.features.map((feature, fIndex) => {
            const panelIndex = fIndex + 1;
            const isLastPanel = fIndex === service.features.length - 1;

            return (
              <div class="panel w-screen h-screen flex-shrink-0 relative flex items-center justify-center px-6 md:px-24 bg-black">
                <div class="w-full h-full max-h-[80vh] flex flex-col lg:flex-row gap-12 lg:gap-20 items-center justify-center">
                  <div class="flex-1 flex flex-col items-start gap-4 md:gap-6 w-full lg:max-w-xl">
                    <span class="feature-anim-text text-[0.65rem] md:text-xs tracking-[0.2em] text-white/50 uppercase">
                      {service.serviceName}
                    </span>
                    <h3 class="feature-anim-text text-3xl md:text-4xl lg:text-5xl font-semibold leading-tight m-0">
                      {feature.featureName}
                    </h3>
                    <p class="feature-anim-text text-sm md:text-base font-light text-white/70 leading-relaxed m-0">
                      {feature.description}
                    </p>

                    <div class="feature-anim-text flex gap-6 mt-8">
                      <button
                        class="nav-btn group flex items-center gap-2 text-white/50 hover:text-white transition-colors"
                        data-target-index={panelIndex - 1}
                      >
                        <svg
                          class="w-4 h-4 transform group-hover:-translate-x-1 transition-transform"
                          fill="none"
                          stroke="currentColor"
                          viewBox="0 0 24 24"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="1.5"
                            d="M15 19l-7-7 7-7"
                          />
                        </svg>
                        <span class="text-xs tracking-widest uppercase">
                          Anterior
                        </span>
                      </button>

                      {!isLastPanel && (
                        <button
                          class="nav-btn group flex items-center gap-2 text-white/50 hover:text-white transition-colors"
                          data-target-index={panelIndex + 1}
                        >
                          <span class="text-xs tracking-widest uppercase">
                            Siguiente
                          </span>
                          <svg
                            class="w-4 h-4 transform group-hover:translate-x-1 transition-transform"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              stroke-width="1.5"
                              d="M9 5l7 7-7 7"
                            />
                          </svg>
                        </button>
                      )}
                    </div>
                  </div>

                  <div class="flex-1 relative w-full h-[40vh] lg:h-[70vh] flex items-center justify-center">
                    {feature.images &&
                      feature.images.length > 0 &&
                      feature.images.map((img, imgIndex) => {
                        const isMultiple = feature.images.length > 1;
                        let imgClasses =
                          "feature-anim-img object-cover rounded-md shadow-2xl ";

                        // Lógica de galería superpuesta
                        if (isMultiple) {
                          imgClasses += "absolute ";
                          if (imgIndex === 0)
                            imgClasses +=
                              "w-2/3 h-auto md:h-3/4 top-0 left-0 z-10 ";
                          else if (imgIndex === 1)
                            imgClasses +=
                              "w-3/5 h-auto md:h-2/3 bottom-0 right-0 z-20 translate-y-4 translate-x-4 border-4 border-black ";
                          else imgClasses += "hidden "; // Ocultamos más de 2 imágenes por simplicidad, o puedes agregar más lógica
                        } else {
                          imgClasses += "w-full max-h-full ";
                        }

                        return (
                          <img
                            src={img}
                            alt={feature.featureName}
                            class={imgClasses}
                          />
                        );
                      })}
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    ))
  }
</section>

<script>
  import gsap from "gsap";
  import ScrollTrigger from "gsap/ScrollTrigger";
  import ScrollToPlugin from "gsap/ScrollToPlugin";

  // Registramos los plugins necesarios
  gsap.registerPlugin(ScrollTrigger, ScrollToPlugin);

  document.addEventListener("DOMContentLoaded", () => {
    const pinContainers = document.querySelectorAll(".service-pin-container");

    pinContainers.forEach((container) => {
      const track = container.querySelector(".horizontal-track") as HTMLElement;
      if (!track) return;

      const panels = container.querySelectorAll(".panel");

      // Cantidad de pixeles horizontales que nos debemos mover
      const getScrollAmount = () => track.scrollWidth - window.innerWidth;

      // 1. Animación Horizontal Principal
      const scrollTween = gsap.to(track, {
        x: () => -getScrollAmount(),
        ease: "none",
        scrollTrigger: {
          trigger: container,
          pin: true,
          scrub: 1,
          end: () => `+=${getScrollAmount()}`,
          invalidateOnRefresh: true,
        },
      });

      // 2. Animaciones de Entrada dentro de los paneles (containerAnimation)
      panels.forEach((panel) => {
        const texts = panel.querySelectorAll(".feature-anim-text");
        const images = panel.querySelectorAll(".feature-anim-img");

        // Animamos los textos para que entren suavemente desde abajo
        if (texts.length > 0) {
          gsap.from(texts, {
            y: 40,
            autoAlpha: 0,
            stagger: 0.1,
            duration: 0.8,
            ease: "power3.out",
            scrollTrigger: {
              trigger: panel,
              containerAnimation: scrollTween, // ¡CRÍTICO! Vincula el trigger al movimiento del track horizontal
              start: "left 70%", // Inicia cuando el lado izquierdo del panel llega al 70% de la pantalla
              toggleActions: "play none none reverse", // Se reproduce al entrar, se revierte al salir hacia atrás
            },
          });
        }

        // Animamos las imágenes para que entren desde la derecha
        if (images.length > 0) {
          gsap.from(images, {
            x: 60,
            autoAlpha: 0,
            stagger: 0.15,
            duration: 1,
            ease: "power3.out",
            scrollTrigger: {
              trigger: panel,
              containerAnimation: scrollTween,
              start: "left 70%",
              toggleActions: "play none none reverse",
            },
          });
        }
      });

      // 3. Lógica de los botones de Navegación (Prev/Next)
      const navButtons = container.querySelectorAll(".nav-btn");

      navButtons.forEach((btn) => {
        btn.addEventListener("click", function () {
          const targetIndex = parseInt(
            (this as HTMLElement).dataset.targetIndex || "0",
          );
          const st = scrollTween.scrollTrigger;

          if (st) {
            // Calculamos cuánto scroll vertical equivale a la posición del panel destino
            // Multiplicamos el índice por el ancho de la pantalla actual.
            const targetX = targetIndex * window.innerWidth;

            // Calculamos el porcentaje de progreso (0 a 1) que representa esa distancia X
            const progress = targetX / getScrollAmount();

            // Mapeamos ese progreso a la distancia vertical total del ScrollTrigger
            const targetScroll = st.start + (st.end - st.start) * progress;

            // Hacemos un smooth scroll a esa posición exacta
            gsap.to(window, {
              scrollTo: { y: targetScroll, autoKill: true },
              duration: 1.2,
              ease: "power3.inOut",
            });
          }
        });
      });
    });
  });
</script>
