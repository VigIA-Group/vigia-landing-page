---
import CompanyDb from "../../database/company.json";
import type { Company } from "../../models/Company";
const company = CompanyDb as Company;
---

<!--
  Trick: el padre es fixed, top-0, ancho automático, sin fondo.
  El hijo tiene bg-black y border-radius solo en las esquinas inferiores.
  Como el padre está pegado al top del viewport, las esquinas superiores
  del hijo quedan ocultas fuera del viewport — solo se ven las inferiores.
-->
<div class="fixed top-0 left-1/2 -translate-x-1/2 z-50">
  <div
    id="floating-nav"
    class="flex items-center justify-center
           bg-black
           rounded-b-[18px]
           shadow-[0_6px_24px_rgba(0,0,0,0.6)]
           h-[34px] px-2 whitespace-nowrap"
  >
    <div class="flex items-center gap-1">
      <!-- NAV LINKS -->
      <nav class="flex items-center gap-0.5">
        <a
          href="#hero"
          class="px-2.5 py-1 text-[0.62rem] font-medium tracking-wide text-white/55 hover:text-white rounded-full hover:bg-white/8 transition-all duration-200"
        >
          Inicio
        </a>
        <a
          href="#why-us"
          class="px-2.5 py-1 text-[0.62rem] font-medium tracking-wide text-white/55 hover:text-white rounded-full hover:bg-white/8 transition-all duration-200"
        >
          ¿Por qué nosotros?
        </a>
        <a
          href="#services"
          class="px-2.5 py-1 text-[0.62rem] font-medium tracking-wide text-white/55 hover:text-white rounded-full hover:bg-white/8 transition-all duration-200"
        >
          Servicios
        </a>
        <a
          href="#footer"
          class="px-2.5 py-1 text-[0.62rem] font-medium tracking-wide text-white/55 hover:text-white rounded-full hover:bg-white/8 transition-all duration-200"
        >
          Contacto
        </a>
      </nav>

      <!-- DIVIDER -->
      <div class="w-px h-3 bg-white/15 mx-1 flex-shrink-0"></div>

      <!-- SOCIAL LINKS AS TEXT -->
      <div class="flex items-center gap-0">
        {
          company.socialMedia.map((social) => (
            <a
              href={social.url}
              target="_blank"
              rel="noopener noreferrer"
              class="px-2 py-1 text-[0.55rem] font-light tracking-widest uppercase text-white/35 hover:text-white/70 rounded-full hover:bg-white/8 transition-all duration-200"
            >
              {social.name}
            </a>
          ))
        }
      </div>

      <!-- DIVIDER -->
      <div class="w-px h-3 bg-white/15 mx-1 flex-shrink-0"></div>

      <!-- CTA -->
      <a
        href="#waitlist-section"
        id="go-to-register"
        class="inline-flex items-center gap-1.5 pl-3 pr-0.5 py-0.5 rounded-full text-[0.62rem] font-medium tracking-wide
             bg-white/8 text-white/80 border border-white/15
             hover:border-white/30 hover:text-white hover:bg-white/12 transition-all duration-200 flex-shrink-0"
      >
        Contactanos
        <span
          class="w-4 h-4 rounded-full bg-white/12 border border-white/20 flex items-center justify-center flex-shrink-0"
        >
          <svg
            width="8"
            height="8"
            viewBox="0 0 10 10"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M2 8L8 2M8 2H3.5M8 2V6.5"
              stroke="white"
              stroke-width="1.3"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </span>
      </a>
    </div>
  </div><!-- /outer wrapper -->

  <script>
    import { logEvent } from "firebase/analytics";
    import { analytics } from "../../firebase/client";

    // CTA analytics
    const boton = document.getElementById("go-to-register");
    if (boton) {
      boton.addEventListener("click", () => {
        if (analytics) {
          logEvent(analytics, "Boton de inscribirse");
          console.log("Evento enviado a Analytics");
        }
      });
    }
  </script>
</div>
