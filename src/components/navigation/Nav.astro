---
import CompanyDb from "../../database/company.json";
import type { Company } from "../../models/Company";
const company = CompanyDb as Company;
---

<div
  id="floating-nav"
  class="fixed top-0 left-1/2 -translate-x-1/2 z-50 flex items-center
         bg-background shadow-[0_6px_24px_rgba(0,0,0,0.6)]
         h-[34px] px-2 whitespace-nowrap"
  style="border-radius: 18px;"
>
  <div class="flex items-center gap-1">
    <!-- NAV LINKS -->
    <nav class="flex items-center gap-0.5">
      <a
        href="#hero"
        class="px-2.5 py-1 text-[0.62rem] font-medium tracking-wide text-text/55 hover:text-text rounded-full hover:bg-text/8 transition-all duration-200"
      >
        Inicio
      </a>
      <a
        href="#services"
        class="px-2.5 py-1 text-[0.62rem] font-medium tracking-wide text-text/55 hover:text-text rounded-full hover:bg-text/8 transition-all duration-200"
      >
        Servicios
      </a>
      <a
        href="#why-us"
        class="px-2.5 py-1 text-[0.62rem] font-medium tracking-wide text-text/55 hover:text-text rounded-full hover:bg-text/8 transition-all duration-200"
      >
        ¿Por qué nosotros?
      </a>
      <a
        href="#footer"
        class="px-2.5 py-1 text-[0.62rem] font-medium tracking-wide text-text/55 hover:text-text rounded-full hover:bg-text/8 transition-all duration-200"
      >
        Contacto
      </a>
    </nav>

    <!-- DIVIDER -->
    <div class="w-px h-3 bg-text/15 mx-1 flex-shrink-0"></div>

    <!-- SOCIAL LINKS AS TEXT -->
    <div class="flex items-center gap-0">
      {
        company.socialMedia.map((social) => (
          <a
            href={social.url}
            target="_blank"
            rel="noopener noreferrer"
            class="px-2 py-1 text-[0.55rem] font-light tracking-widest uppercase text-text/35 hover:text-text/70 rounded-full hover:bg-text/8 transition-all duration-200"
          >
            {social.name}
          </a>
        ))
      }
    </div>

    <!-- DIVIDER -->
    <div class="w-px h-3 bg-text/15 mx-1 flex-shrink-0"></div>

    <!-- CTA -->
    <a
      href="#waitlist-section"
      id="go-to-register"
      class="inline-flex items-center gap-1.5 pl-3 pr-0.5 py-0.5 rounded-full text-[0.62rem] font-medium tracking-wide
             bg-text/8 text-text/80 border border-text/15
             hover:border-text/30 hover:text-text hover:bg-text/12 transition-all duration-200 flex-shrink-0"
    >
      Reserva un Espacio
      <span
        class="w-4 h-4 rounded-full bg-text/12 border border-text/20 flex items-center justify-center flex-shrink-0"
      >
        <svg
          width="8"
          height="8"
          viewBox="0 0 10 10"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M2 8L8 2M8 2H3.5M8 2V6.5"
            stroke="currentColor"
            class="text-text"
            stroke-width="1.3"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </span>
    </a>
  </div>
</div>

<script>
  import { logEvent } from "firebase/analytics";
  import { analytics } from "../../firebase/client";

  const boton = document.getElementById("go-to-register");
  if (boton) {
    boton.addEventListener("click", () => {
      if (analytics) {
        logEvent(analytics, "Boton de inscribirse");
        console.log("Evento enviado a Analytics");
      }
    });
  }
</script>
