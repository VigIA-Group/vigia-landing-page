---
import CompanyDb from "../../database/company.json";
import type { Company } from "../../models/Company";
const company = CompanyDb as Company;

const currentYear = new Date().getFullYear();
---

<footer
  class="relative z-10 py-16 px-6 border-t border-primary/10 bg-transparent"
  id="footer"
>
  <div class="max-w-[1000px] mx-auto">
    <div class="flex flex-col md:flex-row justify-between gap-10 mb-20">
      <div class="flex flex-col items-start w-full md:w-auto">
        <a href="#hero" class="mb-3 block transition-opacity hover:opacity-80">
          {
            company.logos?.iconTitleRow ? (
              <img
                src={company.logos.iconTitleRow}
                alt={`${company.name} logo`}
                class="h-5 w-auto object-contain"
              />
            ) : (
              <h3 class="font-bold text-lg text-text uppercase tracking-tight">
                {company.name || "VigIA"}&copy;
              </h3>
            )
          }
        </a>
        <p
          class="text-[0.7rem] text-muted flex items-center gap-1.5 font-medium"
        >
          Diseñado con <span class="text-primary">♥</span> en 🇧🇴.
        </p>
      </div>

      <div class="flex flex-wrap md:flex-nowrap gap-x-12 gap-y-10">
        <div class="min-w-[120px]">
          <h4
            class="font-bold text-[0.65rem] uppercase tracking-widest text-text mb-4"
          >
            Enfoque
          </h4>
          <ul class="space-y-2.5">
            <li>
              <span
                class="text-[0.75rem] font-medium text-muted block"
                >Inteligencia Activa</span
              >
            </li>
            <li>
              <span
                class="text-[0.75rem] font-medium text-muted block"
                >Seguridad Proactiva</span
              >
            </li>
            <li>
              <span
                class="text-[0.75rem] font-medium text-muted block"
                >Análisis de Espacios</span
              >
            </li>
            <li>
              <span
                class="text-[0.75rem] font-medium text-muted block"
                >Toma de Decisiones</span
              >
            </li>
          </ul>
        </div>

        <div class="min-w-[160px]">
          <h4
            class="font-bold text-[0.65rem] uppercase tracking-widest text-text mb-4"
          >
            Servicios Principales
          </h4>
          <ul class="space-y-2.5">
            <li>
              <a
                href="#services"
                class="text-[0.75rem] font-medium text-muted hover:text-text transition-colors block"
                >Analítica de Personas</a
              >
            </li>
            <li>
              <a
                href="#services"
                class="text-[0.75rem] font-medium text-muted hover:text-text transition-colors block"
                >Detección de Intrusos</a
              >
            </li>
            <li>
              <span
                class="text-[0.75rem] font-medium text-muted block"
                >Visión en Tiempo Real</span
              >
            </li>
            <li>
              <span
                class="text-[0.75rem] font-medium text-muted block"
                >Integración PTZ Inteligente</span
              >
            </li>
          </ul>
        </div>

        <div class="min-w-[140px]">
          <h4
            class="font-bold text-[0.65rem] uppercase tracking-widest text-text mb-4"
          >
            Capacidades
          </h4>
          <ul class="space-y-2.5">
            <li>
              <span
                class="text-[0.75rem] font-medium text-muted block"
                >Mapas de Calor</span
              >
            </li>
            <li>
              <span
                class="text-[0.75rem] font-medium text-muted block"
                >Alertas Instantáneas</span
              >
            </li>
            <li>
              <span
                class="text-[0.75rem] font-medium text-muted block"
                >Reportes Automatizados</span
              >
            </li>
            <li>
              <span
                class="text-[0.75rem] font-medium text-muted block"
                >Control de Aforos</span
              >
            </li>
            <li>
              <span
                class="text-[0.75rem] font-medium text-muted block"
                >Definición de Áreas</span
              >
            </li>
            <li>
              <span
                class="text-[0.75rem] font-medium text-muted block"
                >Análisis de Flujos</span
              >
            </li>
          </ul>
        </div>

        <div class="min-w-[120px]">
          <h4
            class="font-bold text-[0.65rem] uppercase tracking-widest text-text mb-4"
          >
            Conecta
          </h4>
          <ul class="space-y-2.5">
            <li>
              <a
                href="#waitlist-section"
                class="text-[0.75rem] font-medium text-text hover:text-primary transition-colors block"
                >Reserva tu espacio</a
              >
            </li>
            <li>
              <a
                href="mailto:contacto@tuempresa.com"
                class="text-[0.75rem] font-medium text-muted hover:text-text transition-colors block"
                >Contacto</a
              >
            </li>

            {
              company.socialMedia?.map((social) => (
                <li>
                  <a
                    href={social.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-[0.75rem] font-medium text-muted hover:text-text transition-colors block capitalize"
                  >
                    {social.name}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <div class="hidden md:flex items-start">
        <div class="flex gap-[1px]">
          {
            ["V", "i", "g", "I", "A"].map((num) => (
              <div class="w-[14px] h-[20px] flex items-center justify-center border border-muted/20 text-[0.6rem] font-mono text-muted/50 rounded-sm">
                {num}
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <div
      class="flex flex-col md:flex-row justify-center items-center gap-3 md:gap-6 text-[0.7rem] text-muted"
    >
      <span
        >&copy; {currentYear} {company.name || "VigIA"} Technologies Inc.</span
      >
      <a href="#" class="hover:text-text transition-colors"
        >Política de privacidad</a
      >
      <a href="#" class="hover:text-text transition-colors"
        >Términos y condiciones</a
      >
    </div>
  </div>
</footer>
