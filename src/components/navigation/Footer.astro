---
import CompanyDb from "../../database/company.json";
import type { Company } from "../../models/Company";
const company = CompanyDb as Company;

const currentYear = new Date().getFullYear();
---

<footer
  class="relative z-10 border-t border-[var(--color-primary)]/20 bg-[var(--color-surface)]/20 backdrop-blur-md pt-16 pb-8 px-6 md:px-12"
>
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10 mb-12">
      <div class="col-span-1 md:col-span-1 flex flex-col items-start">
        <h3
          class="font-display font-bold text-3xl mb-4 text-[var(--color-text)]"
        >
          {company.name || "VigIA"}
        </h3>
        <p class="text-[var(--color-muted)] text-sm leading-relaxed mb-6">
          Transformamos cámaras de seguridad en sistemas de inteligencia activa.
          La diferencia entre mirar y entender.
        </p>
      </div>

      <div>
        <h4 class="font-semibold mb-4 text-[var(--color-text)]">Plataforma</h4>
        <ul class="space-y-3 text-sm">
          <li>
            <a
              href="#hero-section"
              class="text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors"
            >
              Inicio
            </a>
          </li>
          <li>
            <a
              href="#phase3-root"
              class="text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors"
            >
              Servicios e Inteligencia
            </a>
          </li>
          <li>
            <a
              href="#waitlist-section"
              class="text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors"
            >
              Lista de Espera
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h4 class="font-semibold mb-4 text-[var(--color-text)]">Conecta</h4>
        <div class="flex gap-3 mb-6">
          {
            company.socialMedia?.map((social) => (
              <a
                href={social.url}
                target="_blank"
                rel="noopener noreferrer"
                class="w-8 h-8 rounded-full flex items-center justify-center hover:scale-110 transition-transform"
                title={social.name}
              >
                <img
                  src={social.icon}
                  alt={social.name}
                  class="w-6 h-6 object-contain"
                />
              </a>
            ))
          }
        </div>
        <ul class="space-y-3 text-sm">
          <li>
            <a
              href="#"
              class="text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors"
            >
              Términos de Servicio
            </a>
          </li>
          <li>
            <a
              href="#"
              class="text-[var(--color-muted)] hover:text-[var(--color-text)] transition-colors"
            >
              Política de Privacidad
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h4 class="font-semibold mb-4 text-[var(--color-text)]">
          Acceso Anticipado
        </h4>
        <p class="text-[var(--color-muted)] text-sm mb-5">
          Asegura tu lugar y obtén beneficios exclusivos antes de nuestro
          lanzamiento oficial.
        </p>

        {
          /* El botón exacto que solicitaste, con un inline-block para mantener la estructura */
        }
        <a
          href="#waitlist-section"
          class="inline-block px-5 py-2 text-sm font-semibold rounded-full transition-colors bg-[var(--color-background)] text-[var(--color-text)] border border-[var(--color-primary)]/30 hover:border-[var(--color-primary)] shadow-[0_0_15px_rgba(124,58,237,0.1)] hover:shadow-[0_0_20px_rgba(124,58,237,0.3)]"
        >
          Inscribirse
        </a>
      </div>
    </div>

    <div
      class="pt-8 border-t border-[var(--color-primary)]/20 text-center flex flex-col md:flex-row justify-between items-center gap-4"
    >
      <p class="text-[var(--color-text)] text-xs">
        &copy; {currentYear}
        {company.name || "VigIA"}. Todos los derechos reservados.
      </p>
      <p class="text-[var(--color-text)] text-xs flex items-center gap-1">
        Diseñado con <span class="text-[var(--color-primary)]">♥</span> en Bolivia
      </p>
    </div>
  </div>
</footer>
