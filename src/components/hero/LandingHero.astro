---
import ServicesDb from "../../database/services.json";
import type { Services } from "../../models/Service";
import CompanyDb from "../../database/company.json";
import type { Company } from "../../models/Company";
import waitingListBenefitsDb from "../../database/waitingListBenefits.json";
import type { WaitingList } from "../../models/WaitingList";

import ShaderBackground from "../hero/ShaderBackground";
import WaitlistForm from "../waiting_list/WaitlistForm";

const services = ServicesDb as Services;
const company = CompanyDb as Company;
const waitingListBenefits = waitingListBenefitsDb as WaitingList;

const GRID_COUNT = Math.max(6, services.length);
const FEAT_HEIGHT = 520;
const IMG_SLOTS = [
  { left: "2%", right: "auto", w: "52%", h: "200px", rot: 0, speed: 0.28 },
  { left: "auto", right: "0%", w: "48%", h: "185px", rot: 0, speed: 0.42 },
  { left: "4%", right: "auto", w: "44%", h: "172px", rot: 0, speed: 0.22 },
  { left: "auto", right: "3%", w: "50%", h: "190px", rot: 0, speed: 0.35 },
];

interface CanvasImg {
  src: string;
  si: number;
  fi: number;
  top: number;
  left: string;
  right: string;
  w: string;
  h: string;
  rot: number;
  speed: number;
  isFirst: boolean;
}
const canvasImages: CanvasImg[] = [];
let globalFeatIdx = 0;
for (let si = 0; si < services.length; si++) {
  const feats = services[si].features ?? [];
  for (let fi = 0; fi < feats.length; fi++) {
    const topBase = globalFeatIdx * FEAT_HEIGHT;
    const imgs = feats[fi].images ?? [];
    imgs.slice(0, 4).forEach((src, ii) => {
      const s = IMG_SLOTS[ii % IMG_SLOTS.length];
      const topOffset = ii * 40;
      canvasImages.push({
        src,
        si,
        fi,
        top: topBase + topOffset,
        left: s.left,
        right: s.right,
        w: s.w,
        h: s.h,
        rot: s.rot,
        speed: s.speed,
        isFirst: si === 0 && fi === 0,
      });
    });
    globalFeatIdx++;
  }
}

const clientData = JSON.stringify(
  services.map((s) => ({
    name: s.serviceName,
    image: s.image,
    features: (s.features ?? []).map((f) => ({
      name: f.featureName,
      description: f.description,
    })),
  })),
);
---

<ShaderBackground client:only="react" />
<div id="shader-bg-wrapper">
  <div id="shader-bg-react"></div>
</div>

<div id="scroll-root" class="relative">
  <div id="hero-section" class="relative" style="height: 350vh;">
    <div
      id="hero-sticky"
      class="sticky top-0 h-screen w-full overflow-hidden flex items-center justify-center bg-transparent"
    >
      <div
        id="rect-grid"
        class="absolute inset-0 flex items-center justify-center pointer-events-none"
      >
        {
          Array.from({ length: GRID_COUNT }).map((_, i) => {
            const svc = services[i % services.length];
            const img = svc?.image ?? null;
            return (
              <div
                class="rect-tile absolute rounded-2xl overflow-hidden border border-[var(--color-primary)]/20 bg-[var(--color-surface)]"
                data-index={i}
              >
                {img ? (
                  <img
                    src={img}
                    alt={svc?.serviceName ?? ""}
                    class="w-full h-full object-cover opacity-70"
                  />
                ) : (
                  <div class="w-full h-full bg-[var(--color-surface)]" />
                )}
                <div class="absolute bottom-0 left-0 right-0 p-3 bg-gradient-to-t from-[var(--color-background)] to-transparent">
                  <span class="font-sans text-xs text-[var(--color-muted)]">
                    {svc?.serviceName ?? `Servicio ${i + 1}`}
                  </span>
                </div>
              </div>
            );
          })
        }
      </div>

      <div
        id="hero-content"
        class="relative flex flex-col items-center justify-center text-center px-6 pointer-events-none select-none z-10"
      >
        <h1
          class="font-display font-bold leading-none tracking-tight text-[var(--color-text)]"
          style="font-size: clamp(4rem, 12vw, 10rem);"
        >
          VigIA
        </h1>
        <p
          class="font-display mt-3 text-[var(--color-muted)]"
          style="font-size: clamp(1rem, 2.5vw, 1.5rem); letter-spacing: 0.04em;"
        >
          La diferencia entre mirar y entender.
        </p>
        <p
          class="font-sans mt-4 max-w-lg text-[var(--color-text)] opacity-70"
          style="font-size: clamp(0.85rem, 1.4vw, 1.05rem); line-height: 1.7;"
        >
          Transforma cada cámara en un sistema de inteligencia.
        </p>
        <div id="scroll-hint" class="mt-10 flex flex-col items-center gap-2">
          <span
            class="font-sans text-xs text-[var(--color-muted)] uppercase"
            style="letter-spacing: 0.15em;">Scroll</span
          >
          <div
            class="w-px h-10 relative overflow-hidden bg-[var(--color-primary)]/20"
          >
            <div
              id="scroll-line"
              class="absolute top-0 left-0 w-full bg-[var(--color-primary)]"
              style="height: 40%;"
            >
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div id="phase3-root" class="relative bg-transparent">
    <div
      id="phase3-sticky"
      class="sticky top-0 h-screen w-full flex overflow-hidden z-10 pointer-events-none"
    >
      <div
        class="w-1/2 h-full shrink-0 flex flex-col justify-center px-[4vw] relative z-10 pointer-events-none"
      >
        <div class="relative z-10">
          <div
            id="p3-counter"
            class="font-sans text-[0.6rem] uppercase text-[var(--color-primary)] opacity-85 mb-8"
            style="letter-spacing: 0.22em;"
          >
            01 / {String(services.length).padStart(2, "0")}
          </div>
          <div
            id="p3-svc-name"
            class="font-sans text-[var(--color-muted)] mb-2 will-change-transform will-change-opacity"
            style="font-size: clamp(1rem, 1.5vw, 2rem); letter-spacing: 0.03em;"
          >
            {services[0]?.serviceName}
          </div>
          <div class="overflow-hidden min-h-[3.8em] relative mb-5">
            <div
              id="p3-feat-title"
              class="font-display font-bold text-[var(--color-text)] leading-tight will-change-transform will-change-opacity"
              style="font-size: clamp(4rem, 4vw, 3.2rem);"
            >
              {services[0]?.features?.[0]?.featureName}
            </div>
          </div>
          <div
            class="w-10 h-0.5 bg-[var(--color-primary)] rounded-sm mb-5 opacity-70"
          >
          </div>
          <div class="overflow-hidden min-h-[5.5em] relative">
            <div
              id="p3-feat-desc"
              class="font-sans text-[var(--color-muted)] leading-relaxed max-w-[38ch] will-change-transform will-change-opacity"
              style="font-size: clamp(0.88rem, 1.1vw, 1rem);"
            >
              {services[0]?.features?.[0]?.description}
            </div>
          </div>
          <div id="p3-dots" class="flex gap-1.5 mt-9">
            {
              services[0]?.features?.map((_, fi) => (
                <div
                  style={`height: 5px; border-radius: 3px; transition: all 0.35s ease; width: ${fi === 0 ? 20 : 6}px; background: ${fi === 0 ? "var(--color-primary)" : "var(--color-primary-dark)"}; opacity: ${fi === 0 ? 1 : 0.4}`}
                />
              ))
            }
          </div>
        </div>
      </div>

      <div class="flex-1 h-full relative overflow-clip">
        <div
          id="p3-canvas"
          class="absolute inset-x-0 top-0 will-change-transform"
        >
          {
            canvasImages.map((ci) => (
              <div
                class="p3-canvas-img absolute overflow-hidden border border-[var(--color-primary)]/20 shadow-2xl rounded-xl"
                data-si={ci.si}
                data-fi={ci.fi}
                data-speed={ci.speed}
                data-rot={ci.rot}
                style={`top: ${ci.top}px; left: ${ci.left}; right: ${ci.right}; width: ${ci.w}; height: ${ci.h}; transform: rotate(0deg); opacity: ${ci.isFirst ? 0.75 : 0.35}; filter: ${ci.isFirst ? "none" : "saturate(0.5)"}; will-change: transform, opacity, filter;`}
              >
                <img
                  src={ci.src}
                  alt=""
                  class="w-full h-full object-cover opacity-90"
                />
              </div>
            ))
          }
        </div>

        <div
          class="absolute top-1/2 left-1/2 -translate-x-[38%] -translate-y-1/2 w-[68%] rounded-xl overflow-hidden border border-[var(--color-primary)]/30 shadow-2xl z-10 leading-[0]"
        >
          <img
            id="p3-main-img-el"
            src={services[0]?.image ?? ""}
            alt={services[0]?.serviceName ?? ""}
            class="w-full h-auto block opacity-0 will-change-opacity"
          />
        </div>
      </div>
    </div>

    <div style="height: 50vh;"></div>
    {
      services.map((svc, si) =>
        (svc.features ?? []).map((feat, fi) => (
          <div class="p3-feat-spacer h-screen" data-si={si} data-fi={fi} />
        )),
      )
    }
    <div style="height: 50vh;"></div>
  </div>

  <section
    id="waitlist-section"
    class="min-h-screen flex items-center justify-center p-4 relative z-10 bg-transparent"
  >
    <WaitlistForm data={waitingListBenefits} client:load />
  </section>
</div>

<div
  class="fixed bottom-6 left-1/2 -translate-x-1/2 z-50 group flex items-center p-1.5 rounded-full overflow-hidden transition-all duration-500 max-w-[52px] hover:max-w-[400px] bg-[var(--color-surface)]/80 border border-[var(--color-primary)]/30 backdrop-blur-md shadow-lg"
>
  <div
    class="w-10 h-10 shrink-0 rounded-full flex items-center justify-center pointer-events-none bg-[var(--color-primary)]/15"
  >
    <span class="text-[var(--color-text)] font-bold font-display">V</span>
  </div>

  <div
    class="flex items-center gap-3 px-3 opacity-0 group-hover:opacity-100 transition-opacity duration-500 whitespace-nowrap"
  >
    <div
      class="flex gap-2 items-center bg-[var(--color-background)]/50 rounded-full p-1 border border-[var(--color-primary)]/10"
    >
      {
        company.socialMedia.map((social) => (
          <a
            href={social.url}
            target="_blank"
            rel="noopener noreferrer"
            class="w-8 h-8 rounded-full bg-[var(--color-text)] flex items-center justify-center hover:scale-110 transition-transform"
            title={social.name}
          >
            <img
              src={social.icon}
              alt={social.name}
              class="w-5 h-5 object-contain"
            />
          </a>
        ))
      }
    </div>

    <a
      href="#waitlist-section"
      class="px-5 py-2 text-sm font-semibold rounded-full transition-colors bg-[var(--color-primary)] text-[var(--color-text)] hover:bg-[var(--color-primary-dark)]"
    >
      {waitingListBenefits.call_to_action} ➔
    </a>
  </div>
</div>

<script id="p3-services-data" type="application/json" set:html={clientData} />

<style>
  :root {
    scroll-behavior: auto;
  }

  #shader-bg-wrapper {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    overflow: hidden; /* sin zoom */
  }

  #shader-bg-react {
    width: 100%;
    height: 100%;
  }

  /* Asegura que el canvas WebGL no haga zoom con gestos */
  #shader-bg-react canvas {
    touch-action: none;
    pointer-events: none;
    user-select: none;
  }

  /* El color-background se vuelve semi-transparente para ver el shader */
  #hero-sticky,
  #phase3-root {
    background: transparent !important;
  }

  #hero-sticky {
    will-change: transform;
  }

  .rect-tile {
    will-change: transform, opacity;
    transform-origin: center center;
  }

  #scroll-line {
    animation: scrollPulse 1.6s ease-in-out infinite;
  }
  @keyframes scrollPulse {
    0% {
      transform: translateY(-100%);
      opacity: 1;
    }
    100% {
      transform: translateY(300%);
      opacity: 0;
    }
  }

  .p3-canvas-img {
    transition:
      opacity 0.55s ease,
      filter 0.55s ease;
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  function buildTileLayout() {
    const tiles = document.querySelectorAll<HTMLElement>(".rect-tile");
    const n = tiles.length;
    const W = window.innerWidth;
    const H = window.innerHeight;
    const COLS = 3;
    const ROWS = Math.ceil(n / COLS);
    const GAP = 16;
    const TW = (W - GAP * (COLS + 1)) / COLS;
    const TH = (H - GAP * (ROWS + 1)) / ROWS;

    const layout: { fx: number; fy: number; fw: number; fh: number }[] = [];
    for (let i = 0; i < n; i++) {
      const col = i % COLS;
      const row = Math.floor(i / COLS);
      layout.push({
        fx: GAP + col * (TW + GAP) + TW / 2 - W / 2,
        fy: GAP + row * (TH + GAP) + TH / 2 - H / 2,
        fw: TW,
        fh: TH,
      });
    }
    const heroIdx = Math.floor(ROWS / 2) * COLS + Math.floor(COLS / 2);
    return { tiles, layout, heroIdx, TW, TH, W, H };
  }

  function initTiles() {
    const { tiles, layout, heroIdx, TW, TH, W, H } = buildTileLayout();
    tiles.forEach((tile, i) => {
      if (i === heroIdx) {
        gsap.set(tile, {
          x: 0,
          y: 0,
          width: W * 0.72,
          height: H * 0.78,
          xPercent: -50,
          yPercent: -50,
          left: "50%",
          top: "50%",
          rotation: 0,
          opacity: 0, // Se inicializa en 0 para que no haya imágenes inicialmente
          borderRadius: "1.25rem",
        });
      } else {
        gsap.set(tile, {
          x: ((i % 3) - 1) * W * 0.3,
          y: (Math.floor(i / 3) - 0.5) * H * 0.35,
          width: TW * 1.1,
          height: TH * 1.1,
          xPercent: -50,
          yPercent: -50,
          left: "50%",
          top: "50%",
          rotation: i % 2 === 0 ? -6 : 6,
          opacity: 0,
          borderRadius: "1.25rem",
        });
      }
    });
  }

  function buildHeroPhase() {
    const { tiles, layout, heroIdx } = buildTileLayout();
    const heroContent = document.getElementById("hero-content")!;
    const scrollHint = document.getElementById("scroll-hint")!;

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: "#hero-section",
        start: "top top",
        end: "bottom bottom",
        scrub: 1.2,
      },
    });

    tl.to(heroContent, { opacity: 0, y: -30, duration: 0.3 }, 0);
    tl.to(scrollHint, { opacity: 0, duration: 0.15 }, 0);

    tiles.forEach((tile, i) => {
      if (i !== heroIdx)
        tl.to(tile, { opacity: 1, duration: 0.25 }, 0.05 * (i % 4));
    });

    const { fx, fy, fw, fh } = layout[heroIdx];
    tl.to(
      tiles[heroIdx],
      {
        x: fx,
        y: fy,
        width: fw,
        height: fh,
        xPercent: -50,
        yPercent: -50,
        rotation: 0,
        opacity: 1, // La imagen empieza a aparecer durante el scroll general
        duration: 0.5,
        ease: "none",
      },
      0.3,
    );

    tiles.forEach((tile, i) => {
      if (i === heroIdx) return;
      const { fx, fy, fw, fh } = layout[i];
      tl.to(
        tile,
        {
          x: fx,
          y: fy,
          width: fw,
          height: fh,
          xPercent: -50,
          yPercent: -50,
          rotation: 0,
          opacity: 1,
          duration: 0.5,
          ease: "none",
        },
        0.3 + 0.03 * i,
      );
    });

    // ── Aparece imagen principal del servicio ──
    const mainImg = document.getElementById("p3-main-img-el");
    if (mainImg) {
      gsap.set(mainImg, { opacity: 0 });
      gsap
        .timeline({
          scrollTrigger: {
            trigger: "#hero-section",
            start: "65% top", // segunda mitad del hero-section
            end: "bottom top",
            scrub: 1.5,
          },
        })
        .to(mainImg, { opacity: 0.88, ease: "power1.out", duration: 1 }, 0.1);
    }
  }

  function buildPhase3() {
    const dataEl = document.getElementById("p3-services-data");
    if (!dataEl) return;

    const SERVICES = JSON.parse(dataEl.textContent ?? "[]") as Array<{
      name: string;
      image: string;
      features: Array<{ name: string; description: string }>;
    }>;

    const canvasEl = document.getElementById("p3-canvas")!;
    const canvasImgs = document.querySelectorAll<HTMLElement>(".p3-canvas-img");
    const mainImgEl = document.getElementById(
      "p3-main-img-el",
    ) as HTMLImageElement;
    const counterEl = document.getElementById("p3-counter")!;
    const svcNameEl = document.getElementById("p3-svc-name")!;
    const featTitleEl = document.getElementById("p3-feat-title")!;
    const featDescEl = document.getElementById("p3-feat-desc")!;
    const dotsWrap = document.getElementById("p3-dots")!;
    const spacers = document.querySelectorAll<HTMLElement>(".p3-feat-spacer");

    const phase3Root = document.getElementById("phase3-root")!;
    const CANVAS_SPEED = 0.6;

    let activeSi = 0;
    let activeFi = 0;

    function updateImageStates(si: number, fi: number) {
      canvasImgs.forEach((img) => {
        const imgSi = Number(img.dataset.si);
        const imgFi = Number(img.dataset.fi);

        let targetOpacity: number;
        let targetFilter: string;

        if (imgSi === si && imgFi === fi) {
          targetOpacity = 0.82;
          targetFilter = "saturate(1) brightness(1)";
        } else if (imgSi < si || (imgSi === si && imgFi < fi)) {
          targetOpacity = 0.32;
          targetFilter = "saturate(0.45) brightness(0.75)";
        } else if (imgSi === si && imgFi > fi) {
          targetOpacity = 0.4;
          targetFilter = "saturate(0.55) brightness(0.85)";
        } else {
          targetOpacity = 0.22;
          targetFilter = "saturate(0.25) brightness(0.6)";
        }

        gsap.to(img, {
          opacity: targetOpacity,
          filter: targetFilter,
          duration: 0.65,
          ease: "power2.out",
          overwrite: "auto",
        });
      });
    }

    function animSwap(
      el: HTMLElement,
      newText: string,
      dir: number,
      yRange: number,
      delay = 0,
    ) {
      gsap.killTweensOf(el);
      gsap.to(el, {
        opacity: 0,
        y: dir * -yRange,
        duration: 0.25,
        ease: "power3.in",
        delay,
        onComplete() {
          el.textContent = newText;
          gsap.fromTo(
            el,
            { opacity: 0, y: dir * yRange },
            { opacity: 1, y: 0, duration: 0.5, ease: "power3.out" },
          );
        },
      });
    }

    function rebuildDots(si: number, fi: number) {
      dotsWrap.innerHTML = "";
      (SERVICES[si]?.features ?? []).forEach((_, i) => {
        const d = document.createElement("div");
        Object.assign(d.style, {
          height: "5px",
          borderRadius: "3px",
          transition: "all 0.35s ease",
          width: i === fi ? "20px" : "6px",
          background:
            i === fi ? "var(--color-primary)" : "rgba(167,139,250,0.3)",
        });
        dotsWrap.appendChild(d);
      });
    }

    function transitionContent(
      si: number,
      fi: number,
      prevSi: number,
      prevFi: number,
    ) {
      const svc = SERVICES[si];
      const feat = svc?.features?.[fi];
      if (!svc || !feat) return;

      const dir = si > prevSi || (si === prevSi && fi > prevFi) ? 1 : -1;

      counterEl.textContent = `${String(si + 1).padStart(2, "0")} / ${String(SERVICES.length).padStart(2, "0")}`;

      if (si !== prevSi) {
        animSwap(svcNameEl, svc.name, dir, 14);
        gsap.to(mainImgEl, {
          opacity: 0,
          duration: 0.3,
          onComplete() {
            mainImgEl.src = svc.image;
            gsap.to(mainImgEl, { opacity: 0.88, duration: 0.55 });
          },
        });
      }

      animSwap(featTitleEl, feat.name, dir, 48, 0);
      animSwap(featDescEl, feat.description, dir, 30, 0.06);
      rebuildDots(si, fi);
    }

    ScrollTrigger.create({
      trigger: "#phase3-root",
      start: "top top",
      end: "bottom bottom",
      scrub: 1.8,
      onUpdate(self) {
        const rootH = phase3Root.offsetHeight;
        const travelY = rootH * self.progress * CANVAS_SPEED;
        gsap.set(canvasEl, { y: -travelY });
      },
    });

    canvasImgs.forEach((img) => {
      const speed = parseFloat(img.dataset.speed ?? "0.3");
      const rot = parseFloat(img.dataset.rot ?? "0");
      const yRange = window.innerHeight * speed * 0.6;

      gsap.fromTo(
        img,
        { y: -yRange, rotation: rot },
        {
          y: yRange,
          rotation: rot,
          ease: "none",
          scrollTrigger: {
            trigger: "#phase3-root",
            start: "top bottom",
            end: "bottom top",
            scrub: 2.5,
          },
        },
      );
    });

    spacers.forEach((spacer) => {
      const si = Number(spacer.dataset.si);
      const fi = Number(spacer.dataset.fi);

      ScrollTrigger.create({
        trigger: spacer,
        start: "top 55%",
        end: "bottom 45%",
        onEnter() {
          if (si !== activeSi || fi !== activeFi) {
            const pSi = activeSi,
              pFi = activeFi;
            activeSi = si;
            activeFi = fi;
            transitionContent(si, fi, pSi, pFi);
            updateImageStates(si, fi);
          }
        },
        onEnterBack() {
          if (si !== activeSi || fi !== activeFi) {
            const pSi = activeSi,
              pFi = activeFi;
            activeSi = si;
            activeFi = fi;
            transitionContent(si, fi, pSi, pFi);
            updateImageStates(si, fi);
          }
        },
      });
    });

    updateImageStates(0, 0);
  }

  function init() {
    initTiles();
    buildHeroPhase();
    buildPhase3();
    ScrollTrigger.refresh();
  }

  if (document.readyState === "complete") {
    init();
  } else {
    window.addEventListener("load", init);
  }

  let resizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener("resize", () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      ScrollTrigger.getAll().forEach((t) => t.kill());
      init();
    }, 250);
  });
</script>
