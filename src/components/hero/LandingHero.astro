---
import ServicesDb from "../../database/services.json";
import type { Services } from "../../models/Service";
const services = ServicesDb as Services;

// Gather one image per service for the grid rectangles
const serviceImages = services.map((s) =>
  s.features?.[0]?.images?.[0] ?? null
);

// Fill grid to at least 6 rectangles for visual density
const GRID_COUNT = Math.max(6, services.length);
---

<!-- ============================================================
     PHASE 1 — HERO (fullscreen, zooms out on scroll)
     PHASE 2 — GRID REVEAL (tiled rectangles appear around hero)
     PHASE 3 — FEATURE STICKY (left rect + right scrolling info)
================================================================= -->

<div id="scroll-root" class="relative">

  <!-- ── PHASE 1 & 2 wrapper ── -->
  <div id="hero-section" class="relative" style="height: 350vh;">

    <!-- Sticky container that stays in view while we scroll through phases 1→2 -->
    <div id="hero-sticky" class="sticky top-0 h-screen w-full overflow-hidden flex items-center justify-center" style="background: var(--color-background);">

      <!-- Grid of rectangles (hidden initially, revealed on zoom-out) -->
      <div id="rect-grid" class="absolute inset-0 flex items-center justify-center pointer-events-none">
        {Array.from({ length: GRID_COUNT }).map((_, i) => {
          const svc = services[i % services.length];
          const img = serviceImages[i % serviceImages.length];
          const isHero = i === Math.floor(GRID_COUNT / 2) - (GRID_COUNT % 2 === 0 ? 1 : 0);
          return (
            <div
              class="rect-tile absolute rounded-2xl overflow-hidden"
              data-index={i}
              data-is-hero={isHero ? "true" : "false"}
              style={`background: var(--color-surface); border: 1px solid rgba(124,58,237,0.18);`}
            >
              {img
                ? <img src={img} alt={svc?.name ?? ""} class="w-full h-full object-cover opacity-70" />
                : <div class="w-full h-full" style={`background: hsl(${260 + i * 22}deg 60% ${14 + i * 3}%);`} />
              }
              <!-- subtle label -->
              <div class="absolute bottom-0 left-0 right-0 p-3" style="background: linear-gradient(to top, rgba(5,1,10,0.85), transparent);">
                <span class="font-sans text-xs" style="color: var(--color-muted);">{svc?.name ?? `Servicio ${i + 1}`}</span>
              </div>
            </div>
          );
        })}
      </div>

      <!-- Hero content (centered, on top of grid) -->
      <div id="hero-content" class="relative z-10 flex flex-col items-center justify-center text-center px-6 pointer-events-none select-none">
        <h1
          id="hero-title"
          class="font-display font-bold leading-none tracking-tight"
          style="font-size: clamp(4rem, 12vw, 10rem); color: var(--color-text);"
        >
          VigIA
        </h1>
        <p
          id="hero-sub"
          class="font-display mt-3"
          style="font-size: clamp(1rem, 2.5vw, 1.5rem); color: var(--color-muted); letter-spacing: 0.04em;"
        >
          La diferencia entre mirar y entender.
        </p>
        <p
          id="hero-body"
          class="font-sans mt-4 max-w-lg"
          style="font-size: clamp(0.85rem, 1.4vw, 1.05rem); color: var(--color-text); opacity: 0.7; line-height: 1.7;"
        >
          Transforma cada cámara en un sistema de inteligencia.
        </p>
        <!-- scroll hint -->
        <div id="scroll-hint" class="mt-10 flex flex-col items-center gap-2">
          <span class="font-sans text-xs" style="color: var(--color-muted); letter-spacing: 0.15em; text-transform: uppercase;">Scroll</span>
          <div class="w-px h-10 relative overflow-hidden" style="background: rgba(167,139,250,0.2);">
            <div id="scroll-line" class="absolute top-0 left-0 w-full" style="height: 40%; background: var(--color-primary);"></div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <!-- ── PHASE 3 — Feature sticky section ── -->
  <div id="features-section" style="background: var(--color-background);">
    {services.map((service, si) => {
      const heroImg = service.features?.[0]?.images?.[0] ?? null;
      return (
        <div class="feature-block relative" data-service-index={si} style="min-height: 100vh;">
          <!-- Sticky left image panel -->
          <div class="feature-sticky-wrap sticky top-0 h-screen flex items-stretch pointer-events-none" style="z-index: 5;">
            <div
              class="feature-left-rect"
              data-service-index={si}
              style="width: 42vw; position: absolute; left: 0; top: 0; height: 100vh; overflow: hidden;"
            >
              <div class="w-full h-full relative" style="background: var(--color-surface);">
                {heroImg
                  ? <img src={heroImg} alt={service.name} class="w-full h-full object-cover" style="opacity: 0.85;" />
                  : <div class="w-full h-full" style={`background: hsl(${260 + si * 35}deg 55% 14%);`} />
                }
                <!-- overlay label -->
                <div class="absolute inset-0 flex flex-col justify-end p-8" style="background: linear-gradient(to top, rgba(5,1,10,0.7) 0%, transparent 60%);">
                  <span class="font-sans text-xs mb-2" style="color: var(--color-muted); letter-spacing: 0.15em; text-transform: uppercase;">Servicio {String(si + 1).padStart(2, "0")}</span>
                  <h3 class="font-display font-bold" style="font-size: clamp(1.5rem, 3vw, 2.5rem); color: var(--color-text);">{service.name}</h3>
                </div>
              </div>
            </div>
          </div>

          <!-- Right scrolling content -->
          <div class="feature-right-content" style="margin-left: 46vw; padding: 10vh 4vw 10vh 2vw; min-height: 100vh; display: flex; flex-direction: column; justify-content: center; gap: 3rem;">
            <!-- Service header -->
            <div>
              <div class="font-sans text-xs mb-3" style="color: var(--color-primary); letter-spacing: 0.2em; text-transform: uppercase;">Servicio {String(si + 1).padStart(2, "0")}</div>
              <h2 class="font-display font-bold mb-4" style="font-size: clamp(2rem, 4vw, 3.5rem); color: var(--color-text); line-height: 1.1;">{service.name}</h2>
              <p class="font-sans" style="font-size: 1.05rem; color: var(--color-muted); line-height: 1.75; max-width: 38ch;">{service.description}</p>
            </div>

            <!-- Features list -->
            <div class="flex flex-col gap-6">
              {service.features?.map((feat, fi) => (
                <div
                  class="feature-item rounded-xl p-5"
                  style="background: var(--color-surface); border: 1px solid rgba(124,58,237,0.15);"
                >
                  <div class="flex items-start gap-4">
                    <div class="flex-shrink-0 w-8 h-8 rounded-lg flex items-center justify-center text-xs font-bold font-display" style="background: rgba(124,58,237,0.2); color: var(--color-primary);">
                      {String(fi + 1).padStart(2, "0")}
                    </div>
                    <div>
                      <h4 class="font-display font-semibold mb-1" style="color: var(--color-text); font-size: 1.05rem;">{feat.name}</h4>
                      <p class="font-sans text-sm" style="color: var(--color-muted); line-height: 1.65;">{feat.description}</p>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      );
    })}
  </div>

</div>

<!-- ============================================================  STYLES -->
<style>
  :root {
    scroll-behavior: auto; /* GSAP handles smooth */
  }

  #hero-sticky {
    will-change: transform;
  }

  .rect-tile {
    will-change: transform, opacity;
    transform-origin: center center;
  }

  /* Scroll line animation */
  #scroll-line {
    animation: scrollPulse 1.6s ease-in-out infinite;
  }
  @keyframes scrollPulse {
    0%   { transform: translateY(-100%); opacity: 1; }
    100% { transform: translateY(300%);  opacity: 0; }
  }

  .feature-item {
    transition: border-color 0.3s ease;
  }
  .feature-item:hover {
    border-color: rgba(124, 58, 237, 0.4);
  }
</style>

<!-- ============================================================  GSAP -->
<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  // ── helpers ──────────────────────────────────────────────────────────────
  const vw = () => window.innerWidth;
  const vh = () => window.innerHeight;

  // ── tile layout config ────────────────────────────────────────────────────
  // Build a layout for N tiles around a central hero tile.
  // We'll position them in a rough 3-column grid with the hero in the center.

  function buildTileLayout() {
    const tiles = document.querySelectorAll<HTMLElement>(".rect-tile");
    const n     = tiles.length;
    const W     = vw();
    const H     = vh();

    const COLS = 3;
    const ROWS = Math.ceil(n / COLS);

    // Final (grid) rect size
    const GAP   = 16;
    const TW    = (W - GAP * (COLS + 1)) / COLS;
    const TH    = (H - GAP * (ROWS + 1)) / ROWS;

    // Pre-compute final positions (center of each cell relative to viewport center)
    const layout: { fx: number; fy: number; fw: number; fh: number }[] = [];
    for (let i = 0; i < n; i++) {
      const col = i % COLS;
      const row = Math.floor(i / COLS);
      const fx  = GAP + col * (TW + GAP) + TW / 2 - W / 2;
      const fy  = GAP + row * (TH + GAP) + TH / 2 - H / 2;
      layout.push({ fx, fy, fw: TW, fh: TH });
    }

    // Hero tile index (center of grid)
    const heroIdx = Math.floor(ROWS / 2) * COLS + Math.floor(COLS / 2);

    return { tiles, n, layout, heroIdx, TW, TH, W, H };
  }

  // ── Phase 1 → 2: set initial state (hero = large, others = scattered) ───
  function initTiles() {
    const { tiles, n, layout, heroIdx, TW, TH, W, H } = buildTileLayout();

    // Hero tile starts fullscreen with hero content overlay
    const heroTile = tiles[heroIdx] as HTMLElement;

    tiles.forEach((tile, i) => {
      if (i === heroIdx) {
        // Start: fullscreen-ish
        gsap.set(tile, {
          x:       0,
          y:       0,
          width:   W * 0.72,
          height:  H * 0.78,
          xPercent: -50,
          yPercent: -50,
          left: "50%",
          top:  "50%",
          rotation: 0,
          opacity: 1,
          borderRadius: "1.25rem",
        });
      } else {
        // Start: scattered around the hero with tilt (image2 stacked look)
        const angle   = i % 2 === 0 ? -6 : 6;
        const offsetX = (i % 3 - 1) * W * 0.3;
        const offsetY = (Math.floor(i / 3) - 0.5) * H * 0.35;
        gsap.set(tile, {
          x:       offsetX,
          y:       offsetY,
          width:   TW * 1.1,
          height:  TH * 1.1,
          xPercent: -50,
          yPercent: -50,
          left: "50%",
          top:  "50%",
          rotation: angle,
          opacity: 0,
          borderRadius: "1.25rem",
        });
      }
    });
  }

  // ── Build phase 1→2 ScrollTrigger ────────────────────────────────────────
  function buildHeroPhase() {
    const { tiles, n, layout, heroIdx, TW, TH, W, H } = buildTileLayout();

    const heroContent = document.getElementById("hero-content")!;
    const scrollHint  = document.getElementById("scroll-hint")!;

    // Master timeline scrubbed to scroll
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger:  "#hero-section",
        start:    "top top",
        end:      "bottom bottom",
        scrub:    1.2,
        pin:      false, // sticky is CSS-handled
      },
    });

    // Step 1 (0→30%): fade hero content out + reveal side tiles with rotation
    tl.to(heroContent, { opacity: 0, y: -30, duration: 0.3 }, 0);
    tl.to(scrollHint,  { opacity: 0, duration: 0.15 }, 0);

    tiles.forEach((tile, i) => {
      if (i !== heroIdx) {
        // Bring scattered tiles into view with rotation preserved
        tl.to(tile, { opacity: 1, duration: 0.25 }, 0.05 * (i % 4));
      }
    });

    // Step 2 (30→70%): zoom-out hero tile + straighten all tiles → grid positions
    const { fx: hfx, fy: hfy, fw: hfw, fh: hfh } = layout[heroIdx];

    tl.to(tiles[heroIdx], {
      x:        hfx,
      y:        hfy,
      width:    hfw,
      height:   hfh,
      xPercent: -50,
      yPercent: -50,
      rotation: 0,
      duration: 0.5,
      ease:     "none",
    }, 0.3);

    tiles.forEach((tile, i) => {
      if (i === heroIdx) return;
      const { fx, fy, fw, fh } = layout[i];
      tl.to(tile, {
        x:        fx,
        y:        fy,
        width:    fw,
        height:   fh,
        xPercent: -50,
        yPercent: -50,
        rotation: 0,
        opacity:  1,
        duration: 0.5,
        ease:     "none",
      }, 0.3 + 0.03 * i);
    });
  }

  // ── Phase 3: feature sticky panels ───────────────────────────────────────
  function buildFeaturePhase() {
    const blocks = document.querySelectorAll<HTMLElement>(".feature-block");

    blocks.forEach((block, bi) => {
      const leftRect = block.querySelector<HTMLElement>(".feature-left-rect");
      const items    = block.querySelectorAll<HTMLElement>(".feature-item");

      // Animate feature items in as they scroll into view
      items.forEach((item, ii) => {
        gsap.fromTo(item,
          { opacity: 0, x: 40 },
          {
            opacity:  1,
            x:        0,
            duration: 0.6,
            ease:     "power2.out",
            scrollTrigger: {
              trigger: item,
              start:   "top 85%",
              end:     "top 60%",
              scrub:   false,
              toggleActions: "play none none reverse",
            },
          }
        );
      });

      // Left rect: subtle scale-in when block enters
      if (leftRect) {
        gsap.fromTo(leftRect,
          { opacity: 0, scale: 0.96 },
          {
            opacity:  1,
            scale:    1,
            duration: 0.8,
            ease:     "power2.out",
            scrollTrigger: {
              trigger: block,
              start:   "top 80%",
              toggleActions: "play none none reverse",
            },
          }
        );
      }
    });
  }

  // ── init ─────────────────────────────────────────────────────────────────
  function init() {
    initTiles();
    buildHeroPhase();
    buildFeaturePhase();
    ScrollTrigger.refresh();
  }

  // Run after fonts + layout settle
  if (document.readyState === "complete") {
    init();
  } else {
    window.addEventListener("load", init);
  }

  // Rebuild on resize (debounced)
  let resizeTimer: ReturnType<typeof setTimeout>;
  window.addEventListener("resize", () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      ScrollTrigger.getAll().forEach(t => t.kill());
      init();
    }, 250);
  });
</script>