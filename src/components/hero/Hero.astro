---
import CompanyDb from "../../database/company.json";
import type { Company } from "../../models/Company";

import ServicesDb from "../../database/services.json";
import type { Services } from "../../models/Service";

const company: Company = CompanyDb;
const services = ServicesDb as Services;
---

<section
  id="hero"
  class="relative w-full h-screen bg-background overflow-hidden"
>
  <video
    id="hero-video"
    class="absolute top-1/2 left-1/2 w-[98%] h-[95%] -translate-x-1/2 -translate-y-1/2 object-cover object-top rounded-2xl z-0"
    muted
    playsinline
    data-videos={JSON.stringify(company.videos)}
  >
  </video>

  <div class="absolute inset-0 z-10 pointer-events-none">
    <div
      class="absolute inset-0 bg-gradient-to-b from-background/30 via-transparent to-background/85"
    >
    </div>
    <div
      class="absolute inset-0 bg-gradient-to-r from-background/40 via-transparent to-background/40"
    >
    </div>
    <!-- Mobile-only center darkening -->
    <div class="absolute inset-0 bg-background/50 md:hidden"></div>
  </div>

  <!-- DESKTOP layout -->
  <div
    class="hidden md:grid absolute z-20 bottom-0 left-0 right-0 h-[42%] grid-cols-[25%_50%_25%] items-end [padding-left:clamp(1.5rem,3vw,3rem)] [padding-right:clamp(1.5rem,3vw,3rem)] pb-12 gap-0"
  >
    <div class="flex flex-col items-start justify-end gap-2 pr-6">
      <img
        src={company.logos.iconTitleRow}
        alt={`Logo de ${company.name}`}
        class="hero-logo w-28 md:w-36 lg:w-44 h-auto"
      />
      <p
        class="hero-slogan text-base md:text-xl lg:text-1xl font-semibold leading-snug text-text/90 m-0 tracking-tight"
      >
        {company.slogan}
      </p>
    </div>

    <div
      onclick="document.getElementById('services')?.scrollIntoView({ behavior: 'smooth' })"
      class="hero-center flex flex-col items-center justify-end gap-3 cursor-pointer group"
    >
      <svg
        class="scroll-arrow w-auto text-text/70 group-hover:text-text transition-colors"
        style="height: 72px;"
        viewBox="0 0 24 80"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          d="M12 0L12 76M12 76L4 68M12 76L20 68"
          stroke="currentColor"
          stroke-width="1.2"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
      <div class="flex flex-col items-center text-center gap-[3px]">
        {
          services.map((service) => (
            <span class="block text-[0.6rem] md:text-[0.65rem] font-light uppercase tracking-[0.18em] text-text/55 group-hover:text-text/80 transition-colors leading-tight">
              {service.serviceName}
            </span>
          ))
        }
      </div>
    </div>

    <div class="flex flex-col items-start justify-end gap-3 pl-6">
      <p
        class="hero-description text-xs md:text-sm font-light text-text/70 leading-relaxed m-0"
      >
        {company.shortDescription}
      </p>

      <a
        id="hero-cta-btn"
        href="#waitlist-section"
        class="inline-flex items-center
      gap-2.5 pl-3 pr-2 py-0.5 rounded-full text-xs md:text-sm font-medium
      tracking-wide bg-background backdrop-blur-sm text-text/90 border
      border-text/20 hover:border-text/40 hover:bg-background/80 transition-all
      duration-200"
      >
        Reserva un Espacio
        <span
          class="w-4 h-4 rounded-full bg-text/15 border border-text/20 flex items-center justify-center flex-shrink-0"
        >
          <svg
            width="10"
            height="10"
            viewBox="0 0 10 10"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M2 8L8 2M8 2H3.5M8 2V6.5"
              stroke="currentColor"
              class="text-text"
              stroke-width="1.3"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </span>
      </a>
    </div>
  </div>

  <!-- MOBILE layout -->
  <div
    class="flex md:hidden absolute z-20 inset-0 flex-col items-center justify-center px-6 gap-4"
  >
    <img
      src={company.logos.iconTitleRow}
      alt={`Logo de ${company.name}`}
      class="hero-logo-mobile w-36 h-auto"
    />
    <p
      class="hero-slogan-mobile text-sm font-semibold leading-snug text-text/90 m-0 tracking-tight text-center"
    >
      {company.slogan}
    </p>
    <p
      class="hero-description-mobile text-[0.7rem] font-light text-text/70 leading-relaxed m-0 text-center max-w-[260px]"
    >
      {company.shortDescription}
    </p>

    <a
      id="hero-cta-btn-mobile"
      href="#waitlist-section"
      class="inline-flex
    items-center gap-2.5 pl-3 pr-2 py-0.5 rounded-full text-xs font-medium
    tracking-wide bg-background backdrop-blur-sm text-text/90 border
    border-text/20 hover:border-text/40 hover:bg-background/80 transition-all
    duration-200"
    >
      Reserva un Espacio
      <span
        class="w-4 h-4 rounded-full bg-text/15 border border-text/20 flex items-center justify-center flex-shrink-0"
      >
        <svg
          width="10"
          height="10"
          viewBox="0 0 10 10"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            d="M2 8L8 2M8 2H3.5M8 2V6.5"
            stroke="currentColor"
            class="text-text"
            stroke-width="1.3"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </span>
    </a>
    <div
      onclick="document.getElementById('services')?.scrollIntoView({ behavior: 'smooth' })"
      class="hero-center-mobile flex flex-col items-center gap-2 cursor-pointer group mt-2"
    >
      <div
        class="flex flex-row flex-wrap items-center justify-center gap-x-3 gap-y-0.5"
      >
        {
          services.map((service) => (
            <span class="text-[0.55rem] font-light uppercase tracking-[0.18em] text-text/50 group-hover:text-text/75 transition-colors leading-tight">
              {service.serviceName}
            </span>
          ))
        }
      </div>
      <svg
        class="scroll-arrow-mobile w-auto text-text/60 group-hover:text-text transition-colors"
        style="height: 36px;"
        viewBox="0 0 24 40"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          d="M12 0L12 36M12 36L4 28M12 36L20 28"
          stroke="currentColor"
          stroke-width="1.2"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </div>

    <script>
      import gsap from "gsap";

      document.addEventListener("DOMContentLoaded", () => {
        const videoEl = document.getElementById(
          "hero-video",
        ) as HTMLVideoElement;
        if (videoEl) {
          const videos: string[] = JSON.parse(videoEl.dataset.videos || "[]");
          let currentVideoIndex = 0;

          if (videos.length > 0) {
            videoEl.src = videos[currentVideoIndex];
            videoEl.playbackRate = 1.3;
            videoEl.play().catch((e) => console.warn("Autoplay bloqueado:", e));

            videoEl.addEventListener("ended", () => {
              currentVideoIndex = (currentVideoIndex + 1) % videos.length;
              videoEl.src = videos[currentVideoIndex];
              videoEl.play();
            });
          }
        }

        const isMobile = window.innerWidth < 768;

        if (isMobile) {
          gsap.set(
            [
              ".hero-logo-mobile",
              ".hero-slogan-mobile",
              ".hero-description-mobile",
              "#hero-cta-btn-mobile",
              ".hero-center-mobile",
            ],
            { opacity: 0, visibility: "visible" },
          );

          const tl = gsap.timeline({
            defaults: { ease: "power3.out", duration: 1.2 },
          });
          tl.to(".hero-logo-mobile", { opacity: 1, duration: 1.2, delay: 0.2 })
            .to(".hero-slogan-mobile", { opacity: 1, duration: 1.2 }, "-=1")
            .to(
              ".hero-description-mobile",
              { opacity: 1, duration: 1.2 },
              "-=1",
            )
            .to("#hero-cta-btn-mobile", { opacity: 1, duration: 1.0 }, "-=0.9")
            .to(".hero-center-mobile", { opacity: 1, duration: 1.0 }, "-=0.8");

          gsap.to(".scroll-arrow-mobile", {
            y: 6,
            duration: 1.5,
            repeat: -1,
            yoyo: true,
            ease: "sine.inOut",
          });
        } else {
          gsap.set(
            [
              ".hero-logo",
              ".hero-slogan",
              ".hero-center",
              ".hero-description",
              "#hero-cta-btn",
            ],
            { opacity: 0, visibility: "visible" },
          );

          const tl = gsap.timeline({
            defaults: { ease: "power3.out", duration: 1.2 },
          });
          tl.to(".hero-logo", { y: 0, opacity: 1, duration: 1.2, delay: 0.2 })
            .to(".hero-slogan", { y: 0, opacity: 1, duration: 1.2 }, "-=1")
            .to(".hero-center", { y: 0, opacity: 1, duration: 1.2 }, "-=1")
            .to(".hero-description", { y: 0, opacity: 1, duration: 1.2 }, "-=1")
            .to("#hero-cta-btn", { y: 0, opacity: 1, duration: 1.0 }, "-=0.9");

          gsap.to(".scroll-arrow", {
            y: 10,
            duration: 1.5,
            repeat: -1,
            yoyo: true,
            ease: "sine.inOut",
          });
        }
      });
    </script>
  </div>
</section>
